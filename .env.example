# Peeksy Configuration
# Copy this file to .env and adjust values as needed.

# Server port — both the web UI and signaling server run on this port
PORT=3000

# Room settings
ROOM_MAX_LIFETIME=86400           # Maximum room lifetime in seconds (default: 24 hours)
ROOM_INACTIVITY_TIMEOUT=3600      # Room destroyed after this many seconds of inactivity (default: 1 hour)
MAX_ROOMS=50                      # Maximum simultaneous rooms on this server
MAX_VIEWERS_PER_ROOM=10           # Maximum viewers per room

# STUN server for WebRTC NAT traversal
# Google's public STUN servers are free and reliable
# You can add your own or use multiple, comma-separated
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
